{% set is_master = (inventory_hostname == groups['lb'][0]) %}

vrrp_instance VI_1 {
    state {{ 'MASTER' if is_master else 'BACKUP' }}
    interface {{ keepalived_interface }}
    virtual_router_id 51
    priority {{ 101 if is_master else 100 }}
    advert_int 1

    authentication {
        auth_type PASS
        auth_pass {{ keepalived_auth_pass }}
    }

    virtual_ipaddress {
        {{ floating_ip }}
    }

    nopreempt
}